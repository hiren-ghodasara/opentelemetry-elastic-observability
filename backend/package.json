{
  "name": "coffeebrew-backend",
  "version": "1.0.0",
  "description": "CoffeeBrew demo backend with OpenTelemetry instrumentation",
  "main": "src/server.js",
  "scripts": {
    "start": "node --require ./src/instrumentation.js src/server.js",
    "dev": "nodemon --require ./src/instrumentation.js src/server.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.47.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.51.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.51.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.51.1",
    "@opentelemetry/instrumentation-express": "^0.40.1",
    "@opentelemetry/instrumentation-http": "^0.51.1",
    "@opentelemetry/instrumentation-pg": "^0.40.0",
    "@opentelemetry/instrumentation-redis-4": "^0.40.0",
    "@opentelemetry/resources": "^1.24.0",
    "@opentelemetry/sdk-logs": "^0.51.1",
    "@opentelemetry/sdk-metrics": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.51.1",
    "@opentelemetry/sdk-trace-node": "^1.24.0",
    "@opentelemetry/semantic-conventions": "^1.24.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-transport": "^4.7.1",
    "@opentelemetry/winston-transport": "^0.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
